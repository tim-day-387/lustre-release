# Makefile.in
#
# Template to generate top-level Makefile
#

export this-makefile := $(lastword $(MAKEFILE_LIST))
export lsrctree := $(realpath $(dir $(this-makefile)))

ifneq (@LDISKFS_SUBDIR@,)
obj-m += @LDISKFS_SUBDIR@/
endif

obj-m += lnet/
obj-m += lustre/
obj-m += lustre_compat/

@INCLUDE_RULES@
